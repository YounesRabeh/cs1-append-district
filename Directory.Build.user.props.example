<Project>
  <PropertyGroup>
    <!-- Required: Cities: Skylines managed folder -->
    <CitiesSkylinesManagedDir>/path/to/Cities_Skylines/Cities_Data/Managed</CitiesSkylinesManagedDir>

    <!-- Required when auto-detection cannot find Harmony -->
    <HarmonyDllPath>/path/to/0Harmony.dll</HarmonyDllPath>

    <!-- Optional: where the built DLL is copied after build -->
    <ModOutputDir>/path/to/Cities_Skylines/Addons/Mods/AppendDistrict</ModOutputDir>
  </PropertyGroup>
</Project>
